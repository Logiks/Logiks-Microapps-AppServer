# .env.docker.sample
# Compose-level environment file. Copy to .env.docker (gitignored) and edit.
# These values are interpolated into docker-compose.yml — they do NOT replace
# the application's own .env or config.json (which the container reads from
# CONFIG_FILE).
#
# IMPORTANT: rotate every secret marked "change-me-*" before deploying.

# ---- Image tag for the AppServer build ----
IMAGE_TAG=local

# ---- Host-port mappings ----
APPSERVER_PORT=9999
MYSQL_PORT=3306
REDIS_PORT=6379
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ---- MySQL bootstrap (used only on first start of the mysql container) ----
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=logiks
MYSQL_PASSWORD=change-me-app

# ---- AppServer runtime ----
NODE_ENV=production
SERVER_ID=appserver-01
NAMESPACE=default
CLUSTER_TOKEN=change-me-cluster-token
SESSION_SECRET=change-me-session-secret
ENC_SALT=change-me-enc-salt
CORE_LOGGER_LEVEL=error
SERVER_CONSOLE_LOG_LEVEL=info
